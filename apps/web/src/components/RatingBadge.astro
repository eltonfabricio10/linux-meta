---
interface Props {
  ageMin: number | null;
  source: string | null;
  oars?: Record<string, string> | null;
  label?: string;
  pendingLabel?: string;
  compact?: boolean;
}

const { ageMin, source, oars, label = 'Classificação', pendingLabel = 'Sem classificação', compact = false } = Astro.props;

/* Age spectrum bucket — sage → wheat → amber → rust → plum, no red. */
function bucket(age: number | null): 'pending' | 'a3' | 'a7' | 'a12' | 'a16' | 'a18' {
  if (age == null) return 'pending';
  if (age <= 6) return 'a3';
  if (age <= 11) return 'a7';
  if (age <= 15) return 'a12';
  if (age <= 17) return 'a16';
  return 'a18';
}

const b = bucket(ageMin);
const display = ageMin == null ? '—' : ageMin === 0 ? '0+' : `${ageMin}+`;
const sourceLabel =
  source === 'oars_official' ? 'OARS oficial' :
  source === 'ai_claude_code' ? 'IA · Claude Code' :
  source === 'ai_codex' ? 'IA · Codex' :
  source === 'human_reviewer' ? 'Revisor humano' :
  source ?? '';

const hasOars = !compact && oars && Object.keys(oars).length > 0;
---

<figure class={`ficha b-${b} ${compact ? 'compact' : ''}`} role="group" aria-label={label}>
  {!compact && (
    <div class="ficha-header">
      <span class="ficha-no">FICHA · CLASSIFICAÇÃO</span>
    </div>
  )}
  <div class="ficha-body">
    <span class="numeral" aria-hidden="true">{display}</span>
    <figcaption class="caption">
      <span class="ficha-label">{ageMin == null ? pendingLabel : label}</span>
      {sourceLabel && <span class="ficha-source">{sourceLabel}</span>}
    </figcaption>
  </div>
  {hasOars && (
    <details class="oars">
      <summary>Categorias OARS</summary>
      <ul>
        {Object.entries(oars!).map(([cat, level]) => (
          <li><code>{cat}</code><span class={`lv lv-${level}`}>{level}</span></li>
        ))}
      </ul>
    </details>
  )}
</figure>

<style>
  .ficha {
    --tone: var(--color-ink-muted);
    --tone-soft: var(--color-rule);
    display: flex;
    flex-direction: column;
    gap: 0;
    background: var(--color-paper-elev);
    border-radius: var(--radius-xl);
    padding: 0;
    margin: 0;
    inline-size: max-content;
    max-inline-size: 100%;
    box-shadow: var(--shadow-card);
    overflow: hidden;
  }
  .ficha-header {
    padding: 8px var(--space-4);
    background: color-mix(in srgb, var(--tone) 12%, transparent);
  }
  .ficha-no {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--tone);
  }
  .ficha-body {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-5);
  }
  .numeral {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 3.6rem;
    line-height: 0.95;
    color: var(--tone);
    letter-spacing: -0.04em;
    font-feature-settings: "lnum", "tnum";
  }
  .caption {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-inline-size: 0;
  }
  .ficha-label {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.92rem;
    color: var(--color-ink);
    letter-spacing: -0.01em;
  }
  .ficha-source {
    font-size: var(--text-xs);
    color: var(--color-ink-muted);
    font-family: var(--font-sans);
  }

  .b-a3  { --tone: var(--age-3); }
  .b-a7  { --tone: var(--age-7); }
  .b-a12 { --tone: var(--age-12); }
  .b-a16 { --tone: var(--age-16); }
  .b-a18 { --tone: var(--age-18); }
  .b-pending {
    background: var(--color-paper);
    box-shadow: var(--shadow-xs);
  }
  .b-pending .numeral { color: var(--color-ink-muted); }

  .ficha.compact {
    flex-direction: row;
    align-items: center;
    padding: 4px var(--space-3);
    background: color-mix(in srgb, var(--tone) 10%, var(--color-paper-elev));
    box-shadow: none;
    border-radius: var(--radius-full);
    gap: var(--space-2);
  }
  .ficha.compact .ficha-body {
    padding: 0;
  }
  .ficha.compact .numeral {
    font-size: 1.3rem;
    line-height: 1;
  }
  .ficha.compact .ficha-label { font-size: 0.6rem; }
  .ficha.compact .ficha-source { display: none; }

  .oars {
    margin: 0;
    padding: var(--space-3) var(--space-4) var(--space-3);
    border-block-start: 1px dashed var(--color-rule);
    font-size: var(--text-sm);
  }
  .oars summary {
    cursor: pointer;
    color: var(--color-ink-muted);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    list-style: none;
  }
  .oars summary::-webkit-details-marker { display: none; }
  .oars summary::before {
    content: '+';
    display: inline-block;
    inline-size: 1em;
    color: var(--tone);
  }
  .oars[open] summary::before { content: '−'; }
  .oars ul {
    list-style: none;
    padding: var(--space-3) 0 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--space-1) var(--space-3);
  }
  .oars li {
    display: flex;
    justify-content: space-between;
    gap: var(--space-2);
    border-block-end: 1px dotted var(--color-rule);
    padding: 2px 0;
  }
  .oars code {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--color-ink);
  }
  .lv {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .lv-none     { color: var(--age-3); }
  .lv-mild     { color: var(--age-7); }
  .lv-moderate { color: var(--age-12); }
  .lv-intense  { color: var(--age-18); }
</style>
