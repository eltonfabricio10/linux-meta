---
/**
 * EditOverlay — wrapper that reveals edit affordance only when global
 * edit-mode is on (toggled via Header). Pure CSS activation via the
 * `[data-edit-mode="on"]` attribute on <html>.
 *
 * - Always renders slot content (zero impact on read mode visually).
 * - When edit-mode is on AND user has editor role, shows dashed outline
 *   + floating chip linking to admin deep-link.
 * - Role gating is server-side (chip only emitted for editors).
 *
 * Usage:
 *   <EditOverlay href="/pt/admin/packages/42?focus=summary" field="resumo">
 *     <h1>{pkg.name}</h1>
 *   </EditOverlay>
 */
import { hasRole, type Role } from '~/lib/roles';

interface Props {
  href: string;
  field?: string;
  label?: string;
  allow?: readonly Role[];
  block?: boolean;
}

const {
  href,
  field,
  label,
  allow = ['translator', 'reviewer', 'admin'],
  block = false,
} = Astro.props;
const role = Astro.locals.role;
const show = role && hasRole(role, allow);
const chipLabel = label ?? (field ? `editar ${field}` : 'editar');
---

{show ? (
  <span class:list={['edit-overlay', { block }]} data-edit-overlay>
    <slot />
    <a class="edit-chip" href={href} aria-label={chipLabel} data-edit-chip>
      <span class="pencil" aria-hidden="true">✎</span>
      <span class="lbl">{chipLabel}</span>
    </a>
  </span>
) : (
  <slot />
)}

<style>
  .edit-overlay {
    position: relative;
    display: inline;
  }
  .edit-overlay.block { display: block; }

  .edit-chip {
    position: absolute;
    top: -0.5rem;
    right: -0.5rem;
    display: none;
    align-items: center;
    gap: 0.25rem;
    padding: 0.15rem 0.45rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--color-forest);
    background: var(--color-paper-elev);
    border: 1px solid var(--color-forest);
    border-radius: var(--radius-sm);
    text-decoration: none;
    line-height: 1.3;
    z-index: 2;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.06);
  }
  .edit-chip:hover,
  .edit-chip:focus-visible {
    background: var(--color-forest);
    color: var(--color-paper);
    outline: none;
  }
  .pencil { font-size: 0.9em; }

  :global([data-edit-mode="on"]) .edit-overlay {
    outline: 1px dashed var(--color-forest);
    outline-offset: 4px;
    border-radius: 2px;
  }
  :global([data-edit-mode="on"]) .edit-chip { display: inline-flex; }
</style>
