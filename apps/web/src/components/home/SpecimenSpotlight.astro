---
/**
 * SpecimenSpotlight — §02 da home. Prova o produto em UM objeto concreto:
 * a explicação em linguagem simples (serif = humano) ao lado da ficha de
 * classificação (RatingBadge) e da origem de cada dado (ProvenanceChip).
 * Reusa RatingBadge + ProvenanceChip; sem nova lógica de dados.
 */
import RatingBadge from '~/components/RatingBadge.astro';
import ProvenanceChip from '~/components/ProvenanceChip.astro';
import { localePath, type Locale } from '~/i18n';

interface Props {
  locale: Locale;
  name: string;
  slug: string;
  summary?: string | null;
  plainExplanation?: string | null;
  ageMin?: number | null;
  oars?: Record<string, string> | null;
  ratingSource?: string | null;
  translationSource?: string | null;
  translationStatus?: string | null;
  updatedAt?: string | Date | null;
}

const {
  locale, name, slug, summary, plainExplanation,
  ageMin, oars, ratingSource, translationSource, translationStatus, updatedAt,
} = Astro.props;
const isPt = locale === 'pt';
const href = localePath(locale, `/p/${slug}`);
/* Prefer the plain-language explanation (the differentiator). Fallback to summary. */
const body = plainExplanation?.trim() || summary?.trim() || null;
---

<article class="spotlight">
  <div class="sp-copy">
    <a class="sp-name" href={href}>{name}</a>
    {body && <p class="sp-body">{body}</p>}
    <a class="sp-more" href={href}>{isPt ? 'Ver ficha completa' : 'See the full entry'} →</a>
  </div>
  <aside class="sp-facts" aria-label={isPt ? 'Dados verificáveis' : 'Verifiable data'}>
    <RatingBadge
      ageMin={ageMin ?? null}
      source={ratingSource ?? null}
      oars={oars ?? null}
      label={isPt ? 'Idade recomendada' : 'Recommended age'}
      pendingLabel={isPt ? 'Sem classificação' : 'No rating'}
    />
    <div class="sp-prov">
      <p class="sp-prov-cap">{isPt ? 'De onde vem cada dado' : 'Where each fact comes from'}</p>
      <div class="sp-prov-row">
        <span class="sp-prov-tag">{isPt ? 'Idade' : 'Age'}</span>
        <ProvenanceChip source={ratingSource ?? null} locale={locale} />
      </div>
      <div class="sp-prov-row">
        <span class="sp-prov-tag">{isPt ? 'Descrição' : 'Description'}</span>
        <ProvenanceChip
          source={translationSource ?? null}
          locale={locale}
          status={translationStatus ?? null}
          date={updatedAt ?? null}
        />
      </div>
    </div>
  </aside>
</article>

<style>
  .spotlight {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: var(--space-10);
    align-items: center;
    padding: var(--space-8);
    background: var(--brand-gradient-soft), var(--color-paper-elev);
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-md);
  }
  @media (max-width: 820px) {
    .spotlight { grid-template-columns: 1fr; gap: var(--space-6); }
  }
  .sp-name {
    display: inline-block;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-3xl);
    letter-spacing: -0.02em;
    color: var(--color-ink);
    text-decoration: none;
  }
  .sp-name:hover { color: var(--color-forest); }
  .sp-body {
    margin: var(--space-4) 0 var(--space-5);
    font-family: var(--font-serif);
    font-size: 1.2rem;
    line-height: 1.6;
    color: var(--color-ink);
    max-inline-size: 48ch;
  }
  .sp-more {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-forest);
    text-decoration: none;
  }
  .sp-more:hover { text-decoration: underline; text-underline-offset: 0.2em; }
  .sp-facts { display: grid; gap: var(--space-4); }
  .sp-prov { display: grid; gap: var(--space-2); }
  .sp-prov-row { display: grid; grid-template-columns: 5.5rem 1fr; align-items: center; gap: var(--space-2); }
  .sp-prov-tag {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-ink-muted);
  }
  @media (max-width: 820px) {
    .sp-prov-row { grid-template-columns: 1fr; gap: 0; }
  }
  .sp-prov-cap {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-ink-muted);
    margin: 0 0 var(--space-1);
  }
</style>
