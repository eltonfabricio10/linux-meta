---
export interface Props { as?: keyof HTMLElementTagNameMap }
const { as: Tag = 'article' } = Astro.props;
---
<Tag class="prose-container">
  <slot />
</Tag>
<style>
  .prose-container {
    max-inline-size: 65ch;
    margin-inline: auto;
    padding-inline: var(--space-6);
    font-size: var(--text-lg);
    line-height: var(--leading-body);
  }
  .prose-container :global(h1) {
    font-size: var(--text-4xl);
    margin-block-end: var(--space-3);
    font-variation-settings: "opsz" 36;
  }
  .prose-container :global(h2) {
    font-size: var(--text-2xl);
    margin-block-start: var(--space-12);
    margin-block-end: var(--space-3);
    font-variation-settings: "opsz" 28;
  }
  .prose-container :global(h3) {
    font-size: var(--text-xl);
    margin-block-start: var(--space-8);
    margin-block-end: var(--space-2);
  }
  .prose-container :global(p) {
    margin-block: var(--space-4);
    max-inline-size: none;
  }
  .prose-container :global(p.lead) {
    font-family: var(--font-sans);
    font-style: normal;
    font-weight: 400;
    font-size: 1.15rem;
    line-height: 1.55;
    color: var(--color-ink);
    margin-block-end: var(--space-8);
  }
  .prose-container :global(ul),
  .prose-container :global(ol) {
    padding-inline-start: var(--space-6);
    margin-block: var(--space-4);
  }
  .prose-container :global(li) {
    margin-block: var(--space-2);
  }
  .prose-container :global(blockquote) {
    border-inline-start: 3px solid var(--color-forest);
    padding-inline-start: var(--space-4);
    margin-inline-start: 0;
    margin-block: var(--space-6);
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: var(--text-xl);
    color: var(--color-ink);
  }
  .prose-container :global(code) {
    font-family: var(--font-mono);
    font-size: 0.92em;
    background: var(--color-paper-elev);
    padding: 0.1em 0.35em;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-rule);
  }
  .prose-container :global(pre) {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    background: var(--color-paper-elev);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    overflow-x: auto;
    margin-block: var(--space-6);
  }
  .prose-container :global(pre code) {
    background: none;
    border: none;
    padding: 0;
  }
  .prose-container :global(dl) {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: var(--space-2) var(--space-6);
    margin-block: var(--space-6);
  }
  .prose-container :global(dt) {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-ink-muted);
    padding-block-start: 0.25em;
  }
  .prose-container :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-block: var(--space-6);
    font-size: var(--text-base);
  }
  .prose-container :global(th),
  .prose-container :global(td) {
    text-align: start;
    padding: var(--space-2) var(--space-3);
    border-block-end: 1px solid var(--color-rule);
    vertical-align: baseline;
  }
  .prose-container :global(th) {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-ink-muted);
    font-weight: 500;
    border-block-end: 2px solid var(--color-ink);
  }
</style>
