---
interface Props {
  tone?: 'forest' | 'terracotta' | 'slate' | 'ink';
  variant?: 'wave' | 'thin' | 'double';
  label?: string;
}
const { tone = 'ink', variant = 'wave', label } = Astro.props;
const toneVar: Record<string, string> = {
  forest: 'var(--color-forest)',
  terracotta: 'var(--color-terracotta)',
  slate: 'var(--color-slate-blue)',
  ink: 'var(--color-ink-muted)',
};
const stroke = toneVar[tone];
---
<div class="rule-divider" data-variant={variant} role="separator" aria-label={label}>
  {variant === 'wave' && (
    <svg viewBox="0 0 600 16" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path
        d="M0 8 Q 30 2 60 8 T 120 8 T 180 8 T 240 8 T 300 8 T 360 8 T 420 8 T 480 8 T 540 8 T 600 8"
        fill="none"
        stroke={stroke}
        stroke-width="1.25"
        stroke-linecap="round"
      />
    </svg>
  )}
  {variant === 'thin' && <span class="thin-line" style={`background:${stroke}`}></span>}
  {variant === 'double' && (
    <span class="double-line">
      <span style={`background:${stroke}`}></span>
      <span style={`background:${stroke}`}></span>
    </span>
  )}
  {label && <span class="label" style={`color:${stroke}`}>{label}</span>}
</div>
<style>
  .rule-divider {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-block: var(--space-8);
    width: 100%;
  }
  .rule-divider svg {
    flex: 1;
    height: 12px;
    opacity: 0.85;
  }
  .thin-line {
    flex: 1;
    block-size: 1px;
    display: block;
  }
  .double-line {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .double-line > span {
    block-size: 1px;
    display: block;
  }
  .label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    white-space: nowrap;
  }
</style>
