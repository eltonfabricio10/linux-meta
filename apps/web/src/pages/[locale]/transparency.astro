---
import Base from '~/layouts/Base.astro';
import { getLocaleFromUrl, t, locales } from '~/i18n';
import { meta } from '~/i18n/meta';
import { getSiteStats, getProvenanceBreakdown } from '~/lib/stats';

export const prerender = false;

const localeParam = Astro.params.locale;
if (!localeParam || !(locales as readonly string[]).includes(localeParam)) {
  return new Response(null, { status: 404 });
}
const locale = getLocaleFromUrl(Astro.url);
void t(locale);
const m = meta(locale).transparency;
const [s, prov] = await Promise.all([getSiteStats(), getProvenanceBreakdown()]);
const fmt = new Intl.NumberFormat(locale === 'pt' ? 'pt-BR' : 'en-US');
const totalRatings = s.ratings.imported + s.ratings.ai + s.ratings.human;
const totalTrPkgs = s.translations.packagesWithImported + s.translations.packagesWithAi + s.translations.packagesWithHuman;
const totalTrRows = s.translations.rowsImported + s.translations.rowsAi + s.translations.rowsHuman;

const isPt = locale === 'pt';
const L = {
  banner: isPt ? 'v0.1 · early access · honest by default' : 'v0.1 · early access · honest by default',
  pkgTitle: isPt ? 'Pacotes por origem' : 'Packages by source',
  pkgCap: isPt
    ? 'Todos foram redistribuídos de repositórios upstream. Nada empacotado por este projeto.'
    : 'All redistributed from upstream repositories. Nothing packaged by this project.',
  trTitle: isPt ? 'Traduções por idioma e origem' : 'Translations by locale and provenance',
  trCol: isPt ? ['Idioma', 'Importadas', 'IA (rascunhos)', 'Revisadas por humanos', 'Total'] : ['Locale', 'Imported', 'AI (drafts)', 'Human-reviewed', 'Total'],
  trCap: (loc: string, imp: number, ai: number, hum: number) =>
    isPt
      ? `${fmt.format(imp)} importadas do upstream, ${fmt.format(ai)} geradas por IA (rascunhos), ${fmt.format(hum)} revisadas por humanos (${loc}).`
      : `${fmt.format(imp)} imported from upstream, ${fmt.format(ai)} generated by AI (drafts), ${fmt.format(hum)} human-reviewed (${loc}).`,
  revTitle: isPt ? 'Revisores ativos' : 'Active reviewers',
  revCap: isPt
    ? `“Ativo” = autor de uma ação de revisão registrada no audit_log nos últimos 90 dias. O número total de pessoas com papel reviewer/admin (${fmt.format(prov.reviewers.total_with_role)}) é o teto, não a atividade.`
    : `“Active” = author of a review action recorded in audit_log in the last 90 days. The total number of people with reviewer/admin role (${fmt.format(prov.reviewers.total_with_role)}) is the ceiling, not the activity.`,
  embCap: isPt
    ? 'Vetores semânticos usados pela busca por significado. 100% gerados por este projeto.'
    : 'Semantic vectors used by meaning-based search. 100% generated by this project.',
  footer: isPt
    ? 'Próximo relatório financeiro: a definir. Endpoint público (JSON): '
    : 'Next financial report: to be defined. Public endpoint (JSON): ',
};
---

<Base title={m.title} description={m.intro}>
  <section class="wrap">
    <div class="container-prose">
      <p class="banner">{L.banner}</p>
      <h1>{m.title}</h1>
      <p class="lead">{m.intro}</p>

      <h2>{m.gapTitle}</h2>
      <p>{m.gapIntro}</p>
      <table class="gaps">
        <thead><tr><th scope="col">{locale === 'pt' ? 'Compromisso' : 'Commitment'}</th><th scope="col">{locale === 'pt' ? 'Estado atual' : 'Current state'}</th></tr></thead>
        <tbody>
          {m.gapItems.map((row) => (
            <tr>
              <th scope="row">{row[0]}</th>
              <td>{row[1]}</td>
            </tr>
          ))}
        </tbody>
      </table>

      <h2>{m.metricsTitle}</h2>
      <p>{m.metricsBody}</p>
      <div class="metric-table">
        <article>
          <p class="lab">{locale === 'pt' ? 'Pacotes (redistribuídos)' : 'Packages (redistributed)'}</p>
          <p class="big">{fmt.format(s.packages.total)}</p>
          <p class="sub">{fmt.format(s.packages.canonicals)} {locale === 'pt' ? 'softwares únicos' : 'unique software'}</p>
        </article>
        <article>
          <p class="lab">{locale === 'pt' ? 'Classificações etárias' : 'Age ratings'}</p>
          <p class="big">{fmt.format(totalRatings)}</p>
          <ul class="b">
            <li><span class="d imp"></span>{fmt.format(s.ratings.imported)} {locale === 'pt' ? 'importadas' : 'imported'}</li>
            <li><span class="d ai"></span>{fmt.format(s.ratings.ai)} {locale === 'pt' ? 'IA' : 'AI'}</li>
            <li><span class="d hum"></span>{fmt.format(s.ratings.human)} {locale === 'pt' ? 'humanas' : 'human'}</li>
          </ul>
        </article>
        <article>
          <p class="lab">{locale === 'pt' ? 'Pacotes com descrição traduzida' : 'Packages with translated description'}</p>
          <p class="big">{fmt.format(totalTrPkgs)}</p>
          <ul class="b">
            <li><span class="d imp"></span>{fmt.format(s.translations.packagesWithImported)} {locale === 'pt' ? 'importados' : 'imported'}</li>
            <li><span class="d ai"></span>{fmt.format(s.translations.packagesWithAi)} {locale === 'pt' ? 'IA' : 'AI'}</li>
            <li><span class="d hum"></span>{fmt.format(s.translations.packagesWithHuman)} {locale === 'pt' ? 'humanos' : 'human'}</li>
          </ul>
          <p class="sub">{fmt.format(totalTrRows)} {locale === 'pt' ? 'pares (pacote × idioma) totais' : '(package × locale) pairs total'} · {s.translations.avgLocalesPerPackage} {locale === 'pt' ? 'idiomas/pacote em média' : 'locales/package avg'} · {s.translations.distinctLocales} {locale === 'pt' ? 'idiomas distintos' : 'distinct locales'}</p>
        </article>
        <article>
          <p class="lab">{locale === 'pt' ? 'Embeddings semânticos' : 'Semantic embeddings'}</p>
          <p class="big">{fmt.format(s.embeddings.total)}</p>
          <p class="sub">100% {locale === 'pt' ? 'gerados pelo projeto' : 'project-generated'}</p>
        </article>
        <article>
          <p class="lab">{locale === 'pt' ? 'Revisores ativos (90d)' : 'Active reviewers (90d)'}</p>
          <p class="big">{fmt.format(s.reviewers.active90d)}</p>
          <p class="sub">{fmt.format(s.reviewers.registered)} {locale === 'pt' ? 'registrados' : 'registered'}</p>
        </article>
        <article>
          <p class="lab">{locale === 'pt' ? 'Disputas em aberto' : 'Open disputes'}</p>
          <p class="big">{fmt.format(s.disputes.open)}</p>
        </article>
      </div>

      <h2>{L.pkgTitle}</h2>
      <p>{L.pkgCap}</p>
      <ul class="src">
        {Object.entries(prov.packages.bySource)
          .sort((a, b) => b[1] - a[1])
          .map(([src, n]) => (
            <li><code>{src}</code><span class="bar"><span style={`inline-size:${prov.packages.total > 0 ? (n / prov.packages.total) * 100 : 0}%`}></span></span><strong>{fmt.format(n)}</strong></li>
          ))}
      </ul>

      <h2>{L.trTitle}</h2>
      <table class="tr">
        <thead><tr>{L.trCol.map((c) => <th scope="col">{c}</th>)}</tr></thead>
        <tbody>
          {Object.entries(prov.translations.byLocale)
            .sort((a, b) => (b[1].imported + b[1].ai + b[1].human) - (a[1].imported + a[1].ai + a[1].human))
            .map(([loc, v]) => {
              const tot = v.imported + v.ai + v.human;
              return (
                <tr title={L.trCap(loc, v.imported, v.ai, v.human)}>
                  <th scope="row"><code>{loc}</code></th>
                  <td><span class="d imp"></span>{fmt.format(v.imported)}</td>
                  <td><span class="d ai"></span>{fmt.format(v.ai)}</td>
                  <td><span class="d hum"></span>{fmt.format(v.human)}</td>
                  <td class="n">{fmt.format(tot)}</td>
                </tr>
              );
            })}
        </tbody>
      </table>

      <h2>{L.revTitle}</h2>
      <p class="big-num">{fmt.format(prov.reviewers.active_90d)}</p>
      <p class="cap">{L.revCap}</p>

      <h2>{isPt ? 'Embeddings semânticos' : 'Semantic embeddings'}</h2>
      <p class="big-num">{fmt.format(prov.embeddings.total)}</p>
      <p class="cap">{L.embCap}</p>

      <p class="audit foot">{L.footer}<a href="/api/v1/metrics"><code>/api/v1/metrics</code></a></p>

      <p class="audit">
        {locale === 'pt'
          ? 'Mesmas métricas em formato máquina: '
          : 'Same metrics in machine-readable form: '}
        <a href="/api/v1/metrics"><code>/api/v1/metrics</code></a>
      </p>
    </div>
  </section>
</Base>

<style>
  .wrap { padding-block: var(--space-16) var(--space-24); }
  h1 { margin: 0 0 var(--space-4); }
  .lead { font-size: var(--text-lg); color: var(--color-fg-muted); margin-block-end: var(--space-10); }
  h2 { font-size: var(--text-2xl); margin: var(--space-12) 0 var(--space-4); }
  table.gaps { width: 100%; border-collapse: collapse; margin-block: var(--space-6) var(--space-8); }
  table.gaps th, table.gaps td { text-align: left; padding: var(--space-3) var(--space-4); border-block-end: 1px solid var(--color-border); vertical-align: top; font-size: var(--text-sm); }
  table.gaps thead th { font-family: var(--font-mono); font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-fg-muted); }
  table.gaps tbody th { color: var(--color-navy-900); font-weight: 600; max-inline-size: 40ch; }
  table.gaps tbody td { color: var(--color-stone-500); }
  .metric-table {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-4);
    margin-block: var(--space-6);
  }
  .metric-table article {
    padding: var(--space-5);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-elevated);
  }
  .metric-table .lab { font-family: var(--font-mono); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-fg-muted); margin: 0 0 var(--space-2); }
  .metric-table .big { font-family: var(--font-display); font-size: 1.8rem; color: var(--color-navy-900); font-weight: 600; line-height: 1; margin: 0; }
  .metric-table .sub { font-size: 0.85rem; color: var(--color-stone-500); margin: var(--space-2) 0 0; }
  .b { list-style: none; padding: 0; margin: var(--space-3) 0 0; display: grid; gap: var(--space-1); font-size: 0.82rem; }
  .b li { display: flex; align-items: center; gap: var(--space-2); }
  .d { inline-size: 9px; block-size: 9px; border-radius: 2px; flex: 0 0 auto; }
  .imp { background: var(--color-teal-500); }
  .ai  { background: var(--color-amber-400); }
  .hum { background: var(--color-sage-600); }
  .audit { margin-block-start: var(--space-8); font-size: var(--text-sm); color: var(--color-fg-muted); }
  .audit code { font-family: var(--font-mono); }
  @media (max-width: 760px) { .metric-table { grid-template-columns: 1fr; } }
  .banner {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: var(--color-amber-200);
    color: var(--color-navy-900);
    padding: 4px 10px;
    border-radius: var(--radius-full);
    margin-block-end: var(--space-4);
    font-weight: 700;
  }
  .src { list-style: none; padding: 0; margin: var(--space-4) 0 var(--space-6); display: grid; gap: var(--space-2); }
  .src li { display: grid; grid-template-columns: 7rem 1fr auto; gap: var(--space-3); align-items: center; font-size: 0.9rem; }
  .src code { font-family: var(--font-mono); color: var(--color-teal-700); }
  .src .bar { background: var(--color-stone-100); border-radius: 4px; block-size: 8px; overflow: hidden; }
  .src .bar span { display: block; block-size: 100%; background: var(--color-teal-500); }
  .src strong { font-variant-numeric: tabular-nums; }
  table.tr { width: 100%; border-collapse: collapse; margin-block: var(--space-4) var(--space-6); }
  table.tr th, table.tr td { text-align: left; padding: var(--space-2) var(--space-3); border-block-end: 1px solid var(--color-border); font-size: 0.88rem; }
  table.tr thead th { font-family: var(--font-mono); font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-fg-muted); }
  table.tr td .d { display: inline-block; inline-size: 9px; block-size: 9px; border-radius: 2px; margin-inline-end: 6px; vertical-align: middle; }
  table.tr td.n { font-variant-numeric: tabular-nums; font-weight: 600; text-align: right; }
  .big-num { font-family: var(--font-display); font-size: 2rem; font-weight: 600; color: var(--color-navy-900); margin: var(--space-3) 0 var(--space-2); }
  .cap { color: var(--color-fg-muted); font-size: 0.88rem; max-inline-size: 64ch; }
  .foot { margin-block-start: var(--space-12); padding-block-start: var(--space-6); border-block-start: 1px solid var(--color-border); }
  @media (max-width: 640px) {
    table.gaps,
    table.tr {
      display: block;
      max-inline-size: 100%;
      overflow-x: auto;
      white-space: nowrap;
    }
    .src li {
      grid-template-columns: 1fr;
      gap: var(--space-1);
      padding-block: var(--space-2);
      border-block-end: 1px solid var(--color-border);
    }
    .src .bar { inline-size: 100%; }
  }
</style>
