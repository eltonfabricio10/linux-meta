---
import Base from '~/layouts/Base.astro';
import { getLocaleFromUrl, locales } from '~/i18n';

export const prerender = false;

const localeParam = Astro.params.locale;
if (!localeParam || !(locales as readonly string[]).includes(localeParam)) {
  return new Response(null, { status: 404 });
}
const locale = getLocaleFromUrl(Astro.url);

if (!Astro.locals.user) {
  return Astro.redirect(`/${locale}/auth/login`);
}

const isPt = locale === 'pt';
const tx = {
  title: isPt ? 'Inscrever-se como voluntário' : 'Apply as volunteer',
  intro: isPt
    ? 'Toda candidatura é revisada por um admin antes da ativação. Sem aprovação manual, nada vai ao ar com seu nome.'
    : 'Every application is reviewed by an admin before activation. Nothing is published under your name without manual approval.',
  role: isPt ? 'Função desejada' : 'Requested role',
  rReviewer: isPt ? 'Revisor — ratifica ratings e traduções' : 'Reviewer — ratify ratings and translations',
  rTranslator: isPt ? 'Tradutor — refina descrições por idioma' : 'Translator — refine per-locale copy',
  rContributor: isPt ? 'Contribuidor — sugere pacotes e correções' : 'Contributor — suggest packages and fixes',
  bio: isPt ? 'Bio (40-4000 caracteres)' : 'Bio (40-4000 chars)',
  bioH: isPt ? 'Quem você é, experiência, motivação. Será publicado se aprovado.' : 'Who you are, experience, motivation. Will be published if approved.',
  areas: isPt ? 'Áreas de domínio (opcional)' : 'Domain areas (optional)',
  areasH: isPt ? 'Ex: educação, games, ferramentas dev, áudio profissional' : 'e.g. education, games, dev tools, pro audio',
  langs: isPt ? 'Idiomas (opcional)' : 'Languages (optional)',
  langsH: isPt ? 'Ex: pt, en, es' : 'e.g. en, pt, es',
  links: isPt ? 'Links públicos (opcional)' : 'Public links (optional)',
  linksH: isPt ? 'GitHub, perfil profissional, blog. Um por linha.' : 'GitHub, professional profile, blog. One per line.',
  submit: isPt ? 'Enviar candidatura' : 'Submit application',
  ok: isPt ? 'Candidatura enviada. Você será notificado quando um admin decidir.' : 'Application submitted. You will be notified when an admin decides.',
  err: isPt ? 'Falha ao enviar.' : 'Failed to submit.',
  dup: isPt ? 'Você já tem uma candidatura pendente.' : 'You already have a pending application.',
};
---

<Base title={tx.title}>
  <section class="wrap">
    <div class="container-prose">
      <h1>{tx.title}</h1>
      <p class="intro">{tx.intro}</p>

      <form id="f" class="stack">
        <label>
          <span>{tx.role}</span>
          <select name="requestedRole" required>
            <option value="reviewer">{tx.rReviewer}</option>
            <option value="translator">{tx.rTranslator}</option>
            <option value="contributor">{tx.rContributor}</option>
          </select>
        </label>

        <label>
          <span>{tx.bio}</span>
          <textarea name="bio" minlength="40" maxlength="4000" rows="6" required placeholder={tx.bioH}></textarea>
        </label>

        <label>
          <span>{tx.areas}</span>
          <input name="areas" maxlength="500" placeholder={tx.areasH} />
        </label>

        <label>
          <span>{tx.langs}</span>
          <input name="languages" maxlength="200" placeholder={tx.langsH} />
        </label>

        <label>
          <span>{tx.links}</span>
          <textarea name="links" rows="3" maxlength="1000" placeholder={tx.linksH}></textarea>
        </label>

        <button type="submit" class="primary">{tx.submit}</button>
        <p id="msg" class="msg" role="status" aria-live="polite"></p>
      </form>
    </div>
  </section>
</Base>

<script is:inline type="application/json" id="application-messages" set:html={JSON.stringify({ ok: tx.ok, err: tx.err, dup: tx.dup })}></script>
<script is:inline>
  const f = document.getElementById('f');
  const msg = document.getElementById('msg');
  const messages = JSON.parse(document.getElementById('application-messages')?.textContent || '{}');
  f?.addEventListener('submit', async (e) => {
    e.preventDefault();
    msg.textContent = '';
    const data = Object.fromEntries(new FormData(f).entries());
    for (const k of Object.keys(data)) if (typeof data[k] === 'string' && !data[k].trim()) delete data[k];
    try {
      const r = await fetch('/api/v1/applications', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(data),
      });
      if (r.status === 201) {
        msg.textContent = messages.ok;
        msg.dataset.kind = 'ok';
        f.querySelector('button')?.setAttribute('disabled', 'true');
      } else if (r.status === 409) {
        msg.textContent = messages.dup;
        msg.dataset.kind = 'err';
      } else {
        msg.textContent = messages.err;
        msg.dataset.kind = 'err';
      }
    } catch {
      msg.textContent = messages.err;
      msg.dataset.kind = 'err';
    }
  });
</script>

<style>
  .wrap { padding-block: var(--space-16); }
  .intro { color: var(--color-fg-muted); margin-block: var(--space-4) var(--space-8); }
  .stack { display: grid; gap: var(--space-6); }
  label { display: grid; gap: var(--space-2); }
  label span { font-weight: 600; font-size: 0.9rem; }
  input, textarea, select {
    width: 100%; padding: var(--space-3); border: 1px solid var(--color-border);
    border-radius: 6px; background: var(--color-bg); color: var(--color-fg); font: inherit;
  }
  textarea { resize: vertical; min-height: 5rem; }
  button.primary {
    padding: var(--space-3) var(--space-6); border: 0; border-radius: 6px;
    background: var(--color-accent); color: var(--color-on-accent); font-weight: 600;
    cursor: pointer; justify-self: start;
  }
  button.primary[disabled] { opacity: 0.5; cursor: default; }
  .msg { min-height: 1.25rem; }
  .msg[data-kind='ok'] { color: var(--color-success, #2a7a48); }
  .msg[data-kind='err'] { color: var(--color-danger, #b94f43); }
</style>
