---
import Base from '~/layouts/Base.astro';
import { getLocaleFromUrl, t, locales } from '~/i18n';
import { meta } from '~/i18n/meta';

const localeParam = Astro.params.locale;
if (!localeParam || !(locales as readonly string[]).includes(localeParam)) {
  return new Response(null, { status: 404 });
}
const locale = getLocaleFromUrl(Astro.url);
void t(locale);
const m = meta(locale).sponsor;

const repoUrl = 'https://github.com/eltonfabricio10/linux-meta';
const fundingIssueUrl = `${repoUrl}/issues/new?labels=funding`;
const sponsorUrl = 'https://github.com/sponsors/eltonfabricio10';
---

<Base title={m.title} description={m.intro}>
  <section class="wrap">
    <div class="container-prose">
      <h1>{m.title}</h1>
      <p class="lead">{m.intro}</p>

      <article class="block highlight">
        <h2>{m.supportTitle}</h2>
        <p>{m.supportBody}</p>
        <p>
          <a class="btn" href={sponsorUrl} rel="noopener external" target="_blank">
            {m.ctaSponsor} <span aria-hidden="true">↗</span>
          </a>
        </p>
      </article>

      <article class="block">
        <h2>{m.howTitle}</h2>
        <p>{m.howBody}</p>
      </article>

      <article class="block">
        <h2>{m.interestTitle}</h2>
        <p>{m.interestBody}</p>
        <p>
          <a class="link" href={fundingIssueUrl} rel="noopener external" target="_blank">
            {m.ctaIssue} <span aria-hidden="true">↗</span>
          </a>
        </p>
      </article>
    </div>
  </section>
</Base>

<style>
  .wrap { padding-block: var(--space-16); }
  h1 { margin: 0 0 var(--space-4); }
  .lead { font-size: var(--text-lg); color: var(--color-fg-muted); margin-block-end: var(--space-10); max-inline-size: 60ch; }
  .block { margin-block-end: var(--space-12); }
  .block h2 { font-size: var(--text-2xl); margin: 0 0 var(--space-3); }
  .block.highlight {
    padding: var(--space-8);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--color-amber-200) 25%, transparent);
    border: 1px solid var(--color-amber-400);
  }
  .btn {
    display: inline-block;
    padding: 0.7rem 1.4rem;
    border-radius: var(--radius-full);
    background: var(--color-navy-900);
    color: #fff;
    text-decoration: none;
    font-weight: 600;
    transition: opacity 0.15s ease;
  }
  .btn:hover { opacity: 0.85; }
  .link { color: inherit; font-weight: 600; text-decoration: underline; text-underline-offset: 3px; }
  .link:hover { text-decoration-thickness: 2px; }
</style>
