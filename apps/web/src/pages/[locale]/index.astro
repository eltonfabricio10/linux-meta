---
import Base from '~/layouts/Base.astro';
import EspecimenCard from '~/components/EspecimenCard.astro';
import EditOverlay from '~/components/EditOverlay.astro';
import RuleDivider from '~/components/layout/RuleDivider.astro';
import SpecimenSpotlight from '~/components/home/SpecimenSpotlight.astro';
import DoorwayCard from '~/components/home/DoorwayCard.astro';
import LawBand from '~/components/home/LawBand.astro';
import { getLocaleFromUrl, t, locales, localePath } from '~/i18n';
import { getSiteStats } from '~/lib/stats';
import { getCategoryCounts, getCategoryLabel } from '~/lib/categories';
import { db } from '~/lib/db';
import { sql } from 'drizzle-orm';

const localeParam = Astro.params.locale;
if (!localeParam || !(locales as readonly string[]).includes(localeParam)) {
  return new Response(null, { status: 404 });
}
const locale = getLocaleFromUrl(Astro.url);
const dict = t(locale);
const isPt = locale === 'pt';
const stats = await getSiteStats();
const fmt = new Intl.NumberFormat(isPt ? 'pt-BR' : 'en-US');
const totalRatings = stats.ratings.imported + stats.ratings.ai + stats.ratings.human;
const totalTrPkgs = stats.translations.packagesWithImported + stats.translations.packagesWithAi + stats.translations.packagesWithHuman;
const totalTrRows = stats.translations.rowsImported + stats.translations.rowsAi + stats.translations.rowsHuman;

/* DB translations use 'pt-br'; web locale is 'pt'. Prefer the localized row, fall back to en. */
const trPrimary = isPt ? 'pt-br' : 'en';

/* ── Hero specimens (real catalog rows) ── */
const demoSlugs = ['gcompris', 'gimp', 'firefox', 'steam'];
const suggestSlugs = ['firefox', 'gimp', 'krita', 'gcompris', 'vlc'];
const demoRows = await db.execute<{
  id: number; canonical_slug: string; name: string;
  age_min: number | null; dominant_source: string | null; summary: string | null;
}>(sql`
  WITH pkg AS (
    SELECT DISTINCT ON (COALESCE(canonical_slug, slug))
      id, COALESCE(canonical_slug, slug) AS canonical_slug, name
    FROM package
    WHERE COALESCE(canonical_slug, slug) IN (${sql.join(demoSlugs.map((s) => sql`${s}`), sql`, `)})
    ORDER BY COALESCE(canonical_slug, slug),
      CASE source WHEN 'flathub' THEN 4 WHEN 'manjaro' THEN 3 WHEN 'aur' THEN 2 ELSE 0 END DESC
  )
  SELECT p.id, p.canonical_slug, p.name, rc.age_min, rc.dominant_source,
    COALESCE(
      (SELECT t.summary FROM package_translation t WHERE t.package_id = p.id AND t.locale = ${trPrimary} LIMIT 1),
      (SELECT t.summary FROM package_translation t WHERE t.package_id = p.id AND t.locale = 'en' LIMIT 1)
    ) AS summary
  FROM pkg p
  LEFT JOIN rating_current rc ON rc.package_id = p.id
`);
const demo = demoSlugs
  .map((s) => demoRows.find((r) => r.canonical_slug === s))
  .filter((r): r is (typeof demoRows)[number] => r !== undefined);

/* ── §02 spotlight: one real entry showing the differentiators ── */
const spotlightSlugs = ['gcompris', 'firefox', 'gimp'];
const spotRows = await db.execute<{
  id: number; canonical_slug: string; name: string;
  age_min: number | null; dominant_source: string | null; oars: Record<string, string> | null;
  summary: string | null; plain_explanation: string | null;
  translated_by: string | null; status: string | null; updated_at: string | null;
}>(sql`
  WITH pkg AS (
    SELECT DISTINCT ON (COALESCE(canonical_slug, slug))
      id, COALESCE(canonical_slug, slug) AS canonical_slug, name
    FROM package
    WHERE COALESCE(canonical_slug, slug) IN (${sql.join(spotlightSlugs.map((s) => sql`${s}`), sql`, `)})
    ORDER BY COALESCE(canonical_slug, slug),
      CASE source WHEN 'flathub' THEN 4 WHEN 'manjaro' THEN 3 WHEN 'aur' THEN 2 ELSE 0 END DESC
  )
  SELECT p.id, p.canonical_slug, p.name,
    rc.age_min, rc.dominant_source, rc.oars,
    tr.summary, tr.plain_explanation, tr.translated_by, tr.status, tr.updated_at
  FROM pkg p
  LEFT JOIN rating_current rc ON rc.package_id = p.id
  LEFT JOIN LATERAL (
    SELECT summary, plain_explanation, translated_by, status, updated_at
    FROM package_translation t
    WHERE t.package_id = p.id AND t.locale IN (${trPrimary}, 'en')
    ORDER BY CASE WHEN t.locale = ${trPrimary} THEN 0 ELSE 1 END,
             CASE t.status WHEN 'official' THEN 0 WHEN 'reviewed' THEN 1 ELSE 2 END
    LIMIT 1
  ) tr ON true
`);
const spotlight = spotlightSlugs
  .map((s) => spotRows.find((r) => r.canonical_slug === s))
  .find((r) => r && (r.plain_explanation || r.summary)) ?? null;

/* ── §03 doorways: curated lists with a few live specimens each ── */
const doorways = [
  { id: 'kids',     tone: 'forest'     as const, maxAge: 9,  requireRated: true,
    title: isPt ? 'Para crianças (6–9)' : 'For kids (6–9)',
    sub:   isPt ? 'Apps educativos com idade verificada.' : 'Educational apps with a checked age.',
    slugs: ['gcompris', 'tuxpaint', 'ktouch', 'kanagram', 'tuxmath', 'gbrainy'] },
  { id: 'school',   tone: 'amber'      as const, maxAge: 14, requireRated: false,
    title: isPt ? 'Para escolas' : 'For schools',
    sub:   isPt ? 'Ciência, matemática e produtividade.' : 'Science, maths and productivity.',
    slugs: ['geogebra', 'stellarium', 'kalzium', 'libreoffice', 'kgeography', 'marble'] },
  { id: 'creative', tone: 'terracotta' as const, maxAge: 99, requireRated: false,
    title: isPt ? 'Criação e mídia' : 'Creative & media',
    sub:   isPt ? 'Imagem, áudio e vídeo livres.' : 'Free image, audio and video.',
    slugs: ['blender', 'krita', 'gimp', 'kdenlive', 'obs-studio', 'audacity'] },
  { id: 'foss',     tone: 'slate'      as const, maxAge: 99, requireRated: false,
    title: isPt ? 'Alternativas livres' : 'Free alternatives',
    sub:   isPt ? 'Trocas abertas para apps proprietários.' : 'Open swaps for proprietary apps.',
    slugs: ['libreoffice', 'thunderbird', 'inkscape', 'gimp', 'darktable', 'audacity'] },
];
const doorwaySlugs = [...new Set(doorways.flatMap((d) => d.slugs))];
const doorwayRows = await db.execute<{
  canonical_slug: string; name: string; age_min: number | null;
}>(sql`
  WITH pkg AS (
    SELECT DISTINCT ON (COALESCE(canonical_slug, slug))
      id, COALESCE(canonical_slug, slug) AS canonical_slug, name
    FROM package
    WHERE COALESCE(canonical_slug, slug) IN (${sql.join(doorwaySlugs.map((s) => sql`${s}`), sql`, `)})
    ORDER BY COALESCE(canonical_slug, slug),
      CASE source WHEN 'flathub' THEN 4 WHEN 'manjaro' THEN 3 WHEN 'aur' THEN 2 WHEN 'debian' THEN 1 ELSE 0 END DESC,
      popularity DESC
  )
  SELECT p.canonical_slug, p.name, rc.age_min
  FROM pkg p
  LEFT JOIN rating_current rc ON rc.package_id = p.id
`);
const doorwayByCanonical = new Map(doorwayRows.map((r) => [r.canonical_slug, r]));
const doorwayCards = doorways.map((d) => ({
  ...d,
  items: d.slugs
    .map((s) => doorwayByCanonical.get(s))
    .filter((r): r is (typeof doorwayRows)[number] => {
      if (!r) return false;
      if (r.age_min == null) return !d.requireRated;
      return r.age_min <= d.maxAge;
    })
    .map((r) => ({ name: r.name, slug: r.canonical_slug, ageMin: r.age_min })),
})).filter((d) => d.items.length > 0);

/* ── §03 category index: top categories by package count ── */
const catCounts = await getCategoryCounts();
const catTotals = new Map<string, number>();
for (const c of catCounts) catTotals.set(c.category, (catTotals.get(c.category) ?? 0) + c.count);
const topCategories = [...catTotals.entries()]
  .filter(([slug]) => slug !== 'other')
  .sort((a, b) => b[1] - a[1])
  .slice(0, 8)
  .map(([slug, count]) => ({ slug, count, label: getCategoryLabel(slug, locale) }));
---

<Base
  title={isPt
    ? 'linux-meta · entenda qualquer app Linux antes de instalar'
    : 'linux-meta · understand any Linux app before you install'}
  description={isPt
    ? 'Busque entre milhares de apps Linux com descrição em linguagem simples, idade recomendada e a origem de cada dado. Dataset aberto para famílias, escolas, distribuições e pesquisa.'
    : 'Search thousands of Linux apps with plain-language descriptions, a recommended age and the origin of every fact. An open dataset for families, schools, distros and research.'}
>
  {/* ============ §01 HERO ============ */}
  <section class="hero">
    <div class="container-page hero-grid">
      <div class="copy">
        <p class="kicker">{isPt ? `${fmt.format(stats.packages.canonicals)} apps Linux, explicados` : `${fmt.format(stats.packages.canonicals)} Linux apps, explained`}</p>
        <h1 class="display">
          {isPt ? 'Entenda qualquer app Linux antes de instalar.' : 'Understand any Linux app before you install.'}
        </h1>
        <p class="lead">
          {isPt
            ? 'Busque entre apps do Manjaro, Flathub, AUR e Debian. Cada um explicado em linguagem simples, no seu idioma, com idade recomendada e a origem de cada dado.'
            : 'Search apps from Manjaro, Flathub, AUR and Debian. Each one explained in plain language, in your language, with a recommended age and the origin of every fact.'}
        </p>
        <form class="search" action={localePath(locale, '/browse')} method="get" role="search">
          <label class="visually-hidden" for="hero-q">{isPt ? 'Buscar programa' : 'Search program'}</label>
          <input
            id="hero-q"
            name="q"
            type="search"
            autocomplete="off"
            placeholder={isPt ? 'Buscar um app: firefox, gimp, gcompris…' : 'Search an app: firefox, gimp, gcompris…'}
          />
          <button type="submit" aria-label={isPt ? 'Buscar' : 'Search'}>
            <span aria-hidden="true">→</span>
          </button>
        </form>
        <div class="hero-aux">
          <p class="suggest">
            <span class="suggest-cap">{isPt ? 'comece por' : 'start with'}:</span>
            {suggestSlugs.map((s, i) => (
              <>
                {i > 0 && <span class="dot" aria-hidden="true"> · </span>}
                <a href={localePath(locale, `/p/${s}`)}>{s}</a>
              </>
            ))}
          </p>
        </div>
      </div>

      <aside class="specimens" aria-label={isPt ? 'Exemplos reais do catálogo' : 'Real catalog examples'}>
        <div class="proof-strip">
          <span><strong>{fmt.format(stats.packages.canonicals)}</strong>{isPt ? 'apps' : 'apps'}</span>
          <span><strong>{fmt.format(totalRatings)}</strong>{isPt ? 'classificações' : 'ratings'}</span>
          <span><strong>{fmt.format(totalTrPkgs)}</strong>{isPt ? 'traduzidos' : 'translated'}</span>
        </div>
        <div class="specimen-grid">
          {demo.map((p) => (
            <EditOverlay href={localePath(locale, `/admin/packages/${p.id}`)} field={p.name}>
              <EspecimenCard
                locale={locale}
                id={p.id}
                slug={p.canonical_slug}
                name={p.name}
                summary={p.summary}
                ageMin={p.age_min}
                source={p.dominant_source}
              />
            </EditOverlay>
          ))}
        </div>
      </aside>
    </div>
  </section>

  {/* ============ §02 THE ANSWER, SHOWN ONCE ============ */}
  {spotlight && (
    <section class="spotlight-sec">
      <div class="container-page">
        <header class="sec-head">
          <p class="section-no">{isPt ? '§ 02 — a resposta, em um exemplo' : '§ 02 — the answer, in one example'}</p>
          <h2>{isPt ? 'Isto é o que uma ficha do linux-meta responde.' : 'This is what a linux-meta entry answers.'}</h2>
          <p class="lead">{isPt
            ? 'O que é, em palavras simples · para qual idade · e de onde veio cada dado. Sem inglês técnico, sem adivinhação.'
            : 'What it is, in plain words · for which age · and where each fact came from. No technical English, no guessing.'}</p>
        </header>
        <SpecimenSpotlight
          locale={locale}
          name={spotlight.name}
          slug={spotlight.canonical_slug}
          summary={spotlight.summary}
          plainExplanation={spotlight.plain_explanation}
          ageMin={spotlight.age_min}
          oars={spotlight.oars}
          ratingSource={spotlight.dominant_source}
          translationSource={spotlight.translated_by}
          translationStatus={spotlight.status}
          updatedAt={spotlight.updated_at}
        />
      </div>
    </section>
  )}

  <RuleDivider tone="forest" variant="wave" />

  {/* ============ §03 DOORWAYS ============ */}
  <section class="doorways-sec">
    <div class="container-page">
      <header class="sec-head">
        <p class="section-no">{isPt ? '§ 03 — comece por uma necessidade' : '§ 03 — start from a need'}</p>
        <h2>{isPt ? 'Listas prontas e categorias reais.' : 'Ready-made lists and real categories.'}</h2>
        <p class="lead">{isPt
          ? 'Pais escolhem por idade, professores por matéria, criadores por mídia. Ou navegue o catálogo inteiro por categoria.'
          : 'Parents pick by age, teachers by subject, creators by media. Or browse the whole catalog by category.'}</p>
      </header>

      <div class="doorways">
        {doorwayCards.map((d) => (
          <DoorwayCard
            locale={locale}
            title={d.title}
            sub={d.sub}
            href={localePath(locale, '/lists')}
            tone={d.tone}
            items={d.items}
          />
        ))}
      </div>

      <nav class="cat-index" aria-label={isPt ? 'Categorias' : 'Categories'}>
        {topCategories.map((c) => (
          <a class="cat-chip" href={localePath(locale, `/browse?category=${c.slug}`)}>
            <span class="cat-label">{c.label}</span>
            <span class="cat-count">{fmt.format(c.count)}</span>
          </a>
        ))}
        <a class="cat-chip cat-all" href={localePath(locale, '/browse')}>
          {isPt ? 'Ver tudo' : 'Browse all'} →
        </a>
      </nav>
    </div>
  </section>

  <RuleDivider tone="ink" variant="wave" />

  {/* ============ §04 TRUST / PROVENANCE ============ */}
  <section class="metrics">
    <div class="container-page">
      <header class="sec-head">
        <p class="section-no">{isPt ? '§ 04 — por que confiar na ficha' : '§ 04 — why you can trust the entry'}</p>
        <h2>{isPt ? 'Cada dado diz de onde veio.' : 'Every fact says where it came from.'}</h2>
        <p class="m-note">{isPt
          ? 'É isso que torna a idade e a descrição confiáveis: nada é apresentado como certo sem origem. Cobertura atual, no aberto.'
          : 'That is what makes the age and the description trustworthy: nothing is presented as fact without an origin. Current coverage, in the open.'}</p>
      </header>

      <ul class="prov-legend">
        <li><i class="bd-imp"></i><strong>{dict.hero.lblImported}</strong> — {isPt ? 'redistribuído do upstream' : 'redistributed from upstream'}</li>
        <li><i class="bd-ai"></i><strong>{dict.hero.lblAi}</strong> — {isPt ? 'sugerido pelos workers, aguarda revisão' : 'suggested by workers, awaiting review'}</li>
        <li><i class="bd-hum"></i><strong>{dict.hero.lblHuman}</strong> — {isPt ? 'revisado por colaborador identificado' : 'reviewed by an identified contributor'}</li>
      </ul>

      <table class="m-table">
        <thead>
          <tr>
            <th scope="col">{isPt ? 'Categoria' : 'Category'}</th>
            <th scope="col" class="num">{isPt ? 'Total' : 'Total'}</th>
            <th scope="col">{isPt ? 'Detalhe' : 'Detail'}</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <th scope="row">{dict.hero.lblCanonicals}</th>
            <td class="num">{fmt.format(stats.packages.canonicals)}</td>
            <td class="detail">{fmt.format(stats.packages.total)} {dict.hero.lblPackages}</td>
          </tr>
          <tr>
            <th scope="row">{dict.hero.lblRatings}</th>
            <td class="num">{fmt.format(totalRatings)}</td>
            <td class="detail">
              <span class="bd"><i class="bd-imp"></i>{fmt.format(stats.ratings.imported)} {dict.hero.lblImported}</span>
              <span class="bd"><i class="bd-ai"></i>{fmt.format(stats.ratings.ai)} {dict.hero.lblAi}</span>
              <span class="bd"><i class="bd-hum"></i>{fmt.format(stats.ratings.human)} {dict.hero.lblHuman}</span>
            </td>
          </tr>
          <tr>
            <th scope="row">{dict.hero.lblTranslations}</th>
            <td class="num">{fmt.format(totalTrPkgs)}</td>
            <td class="detail">
              <span class="bd"><i class="bd-imp"></i>{fmt.format(stats.translations.packagesWithImported)} {dict.hero.lblImported}</span>
              <span class="bd"><i class="bd-ai"></i>{fmt.format(stats.translations.packagesWithAi)} {dict.hero.lblAi}</span>
              <span class="bd"><i class="bd-hum"></i>{fmt.format(stats.translations.packagesWithHuman)} {dict.hero.lblHuman}</span>
              <span class="bd-extra">{fmt.format(totalTrRows)} {dict.hero.lblTrRows} · {stats.translations.avgLocalesPerPackage} {dict.hero.lblTrAvg}</span>
            </td>
          </tr>
          <tr>
            <th scope="row">{dict.hero.lblEmbeddings}</th>
            <td class="num">{fmt.format(stats.embeddings.total)}</td>
            <td class="detail">{isPt ? 'usados para busca semântica e agrupamento' : 'used for semantic search and grouping'}</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  {/* ============ §05 HOW THE DATA IS BUILT ============ */}
  <section class="how" id="how">
    <div class="container-page">
      <header class="how-head">
        <p class="section-no">{isPt ? '§ 05 — como o dado é construído' : '§ 05 — how the data is built'}</p>
        <h2>{isPt ? 'Um pipeline aberto. Sem caixa-preta.' : 'An open pipeline. No black box.'}</h2>
      </header>
      <pre class="term"><code>{`> ingest manjaro flathub aur debian   → ${fmt.format(stats.packages.total)} ${dict.how.t1}
> classify --oars --ai --review       → ${fmt.format(totalRatings)} ${dict.how.t2}
> translate --locales pt,en,es,de,…   → ${fmt.format(totalTrPkgs)} ${dict.how.t3}
> publish --html --dataset --appstream → /${locale}/p/firefox`}</code></pre>

      <ol class="how-steps">
        <li><span class="step-no">01</span><h3>{dict.how.s1t}</h3><p>{dict.how.s1b}</p></li>
        <li><span class="step-no">02</span><h3>{dict.how.s2t}</h3><p>{dict.how.s2b}</p></li>
        <li><span class="step-no">03</span><h3>{dict.how.s3t}</h3><p>{dict.how.s3b}</p></li>
      </ol>
    </div>
  </section>

  <RuleDivider tone="terracotta" variant="wave" />

  {/* ============ §06 WHY THIS MATTERS (compact) ============ */}
  <section class="why-sec">
    <div class="container-page">
      <header class="sec-head">
        <p class="section-no">{isPt ? '§ 06 — por que isto importa agora' : '§ 06 — why this matters now'}</p>
        <h2>{isPt ? 'Metadados claros viram base, não improviso.' : 'Clear metadata becomes a base, not guesswork.'}</h2>
      </header>
      <LawBand locale={locale} />
    </div>
  </section>

  {/* ============ §07 TAKE PART ============ */}
  <section class="support">
    <div class="container-page">
      <header class="sup-head">
        <p class="section-no">{isPt ? '§ 07 — como você participa' : '§ 07 — how you take part'}</p>
        <h2>{isPt
          ? 'A próxima classificação revisada pode evitar uma decisão ruim.'
          : 'The next reviewed rating can prevent a bad decision.'}</h2>
        <p class="lead">{isPt
          ? 'Você não precisa manter uma distribuição para ajudar. Buscar, apontar erro, revisar uma classificação ou traduzir uma descrição já melhora o dado que outras pessoas vão reutilizar.'
          : 'You do not need to maintain a distro to help. Searching, reporting an error, reviewing one rating or translating one description already improves data other people will reuse.'}</p>
      </header>
      <ol class="ladder">
        <li class="rung">
          <span class="rung-tag">{dict.sup.useTag}</span>
          <h3>{dict.sup.useTitle}</h3>
          <p>{dict.sup.useBody}</p>
          <a class="btn btn-ghost" href={localePath(locale, '/browse')}>{dict.sup.useCta} →</a>
        </li>
        <li class="rung">
          <span class="rung-tag">{dict.sup.buildTag}</span>
          <h3>{dict.sup.buildTitle}</h3>
          <p>{dict.sup.buildBody}</p>
          <a class="btn btn-ghost" href={localePath(locale, '/auth/signup')}>{dict.sup.buildCta} →</a>
        </li>
        <li class="rung rung-emph">
          <span class="rung-tag">{dict.sup.sponsorTag}</span>
          <h3>{dict.sup.sponsorTitle}</h3>
          <p>{dict.sup.sponsorBody}</p>
          <a class="btn btn-primary" href={localePath(locale, '/sponsor')}>{dict.sup.sponsorCta} →</a>
        </li>
      </ol>
      <p class="reuse-line">{isPt ? 'Constrói uma distribuição, loja ou pesquisa?' : 'Building a distro, store or research?'}
        <a href={localePath(locale, '/transparency')}>{isPt ? 'Reutilize o dataset aberto (JSON · CSV · AppStream)' : 'Reuse the open dataset (JSON · CSV · AppStream)'} →</a></p>
    </div>
  </section>

  {/* ============ §08 FAQ ============ */}
  <section class="faq">
    <div class="container-prose">
      <p class="section-no">{isPt ? '§ 08 — perguntas frequentes' : '§ 08 — frequently asked'}</p>
      <h2>{isPt ? 'Respostas curtas para dúvidas importantes.' : 'Short answers to important questions.'}</h2>
      <dl class="faq-list">
        <dt>{dict.faq.q1}</dt><dd>{dict.faq.a1}</dd>
        <dt>{dict.faq.q2}</dt><dd>{dict.faq.a2}</dd>
        <dt>{dict.faq.q3}</dt><dd>{dict.faq.a3}</dd>
        <dt>{dict.faq.q4}</dt><dd>{dict.faq.a4}</dd>
      </dl>
    </div>
  </section>
</Base>

<style>
  /* ============ Shared rhythm ============ */
  section { padding-block: var(--space-16); }
  .section-no {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-forest);
    margin: 0 0 var(--space-3);
  }
  h2 {
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    margin: 0 0 var(--space-5);
    line-height: 1.15;
    letter-spacing: -0.01em;
  }
  .lead {
    color: var(--color-ink-muted);
    font-size: var(--text-lg);
    max-inline-size: 58ch;
    line-height: 1.55;
    margin: 0 0 var(--space-6);
  }
  .sec-head { max-inline-size: 64ch; margin-block-end: var(--space-8); }

  .btn {
    display: inline-flex; align-items: center; gap: var(--space-2);
    padding: 0.6rem 1.2rem;
    border-radius: var(--radius-full);
    text-decoration: none;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.92rem;
    transition: background var(--duration-fast), color var(--duration-fast), transform var(--duration-fast), box-shadow var(--duration-fast);
  }
  .btn-primary { background: var(--color-forest); color: var(--color-on-accent); box-shadow: var(--shadow-sm); }
  .btn-primary:hover { background: var(--color-forest-hover); color: var(--color-on-accent); transform: translateY(-1px); box-shadow: var(--shadow-md); }
