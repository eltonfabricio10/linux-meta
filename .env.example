# Postgres
DATABASE_URL=postgres://linuxmeta:linuxmeta@localhost:5433/linuxmeta

# Better Auth — must match the URL you open in the browser (the app runs on :4400),
# otherwise login fails with "Invalid origin".
BETTER_AUTH_SECRET=change-me-to-a-long-random-string-min-32-chars
BETTER_AUTH_URL=http://localhost:4400

# Site
PUBLIC_SITE_URL=http://localhost:4400
PUBLIC_DEFAULT_LOCALE=pt

# Email (Resend) — opcional em dev
RESEND_API_KEY=
EMAIL_FROM="linux-meta <no-reply@example.org>"

# Ollama (embeddings semânticos)
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# DeepSeek (tradução com IA no editor de revisão) — opcional
# Sem a chave, o botão "Traduzir com IA" retorna 503 e o recurso fica inativo.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Cloudflare (produção)
CF_ACCOUNT_ID=
CF_API_TOKEN=
CF_ZONE_ID=
