# HTTPS automático (Let's Encrypt) para o domínio DuckDNS.
# Caddy obtém e renova o certificado sozinho via desafio HTTP-01 na porta 80/443.
linux-meta.duckdns.org {
	encode gzip zstd

	# Hashed build assets (content in filename) — served straight from disk,
	# never wakes up Node/Postgres. Safe to cache forever.
	@hashed path /_astro/*
	handle @hashed {
		header Cache-Control "public, max-age=31536000, immutable"
		root * /srv/static
		file_server
	}

	# Other static files from apps/web/public — not content-hashed, so a
	# shorter cache in case they're replaced on a future deploy.
	@static path /favicon.svg /robots.txt /humans.txt /og-default.svg /fonts/* /.well-known/*
	handle @static {
		header Cache-Control "public, max-age=604800"
		root * /srv/static
		file_server
	}

	# Everything else (pages, API routes) goes to the Astro SSR server.
	reverse_proxy web:4400
}
